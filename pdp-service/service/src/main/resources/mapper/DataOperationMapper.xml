<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slow.service.mapper.DataOperationMapper">

    <resultMap id="BaseResultMap" type="com.slow.pojo.entity.DataOperation">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="operation_type" property="operationType"/>
        <result column="data_type" property="dataType"/>
        <result column="file_url" property="fileUrl"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, operation_type, data_type, file_url, status, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO data_operations (user_id, operation_type, data_type, file_url, status)
        VALUES (#{userId}, #{operationType}, #{dataType}, #{fileUrl}, #{status})
    </insert>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM data_operations
        <where>
            user_id = #{userId}
            <if test="operationType != null and operationType != ''">
                AND operation_type = #{operationType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM data_operations
        WHERE id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE data_operations
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="fileUrl != null">file_url = #{fileUrl}</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
